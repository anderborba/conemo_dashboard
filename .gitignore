# =============================================================================
# .gitignore — Repositório conemo-project/conemo
# Versão: 2026-04-06
# Finalidade: impedir versionamento indevido de dados sensíveis, credenciais,
#             caches locais, exports e arquivos de ambiente.
# =============================================================================

# ---------------------------------------------------------------------------
# Dados clínicos, epidemiológicos e operacionais do projeto CONEMO
# NENHUM dado do projeto deve ser versionado sem revisão formal de governança.
# ---------------------------------------------------------------------------
*.csv
*.parquet
*.xlsx
*.xls
*.sav
*.dta
*.rds
*.feather
*.arrow
*.db
*.sqlite
*.sqlite3

# Dumps e exports temporários
*.dump
*.sql.gz
*.tar.gz
export_*/
dump_*/
output_*/
temp_*/
tmp_*/

# ---------------------------------------------------------------------------
# Credenciais e segredos
# ---------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.json
.streamlit/secrets.toml
service_account*.json
*credentials*.json
*serviceAccount*.json
*firebase*.json
bigquery_credentials.json
gcloud_credentials.json
google_credentials.json
token*.json

# ---------------------------------------------------------------------------
# Ambientes Python
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg

# ---------------------------------------------------------------------------
# Jupyter e notebooks
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints/
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# R e RStudio
# ---------------------------------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj.user
renv/
packrat/

# ---------------------------------------------------------------------------
# Logs e arquivos temporários
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Caches locais e artefatos de execução
# ---------------------------------------------------------------------------
.cache/
cache/
*_cache/
*.cache
__MACOSX/
.quarto/
_site/
_book/

# ---------------------------------------------------------------------------
# Paths e configurações locais
# ---------------------------------------------------------------------------
.vscode/settings.json
local_config.py
local_settings.py
config_local.*

# ---------------------------------------------------------------------------
# Arquivos de IDE e sistema
# ---------------------------------------------------------------------------
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# ---------------------------------------------------------------------------
# Diretórios de dados do projeto (nunca versionar diretamente)
# Cobertura granular: diretório-pai e todos os subdiretórios de dados reais.
# ---------------------------------------------------------------------------
Data/
Data/CSV/
Data/PARQUET/
Data/raw/
Data/exports/
Data/interim/
Data/processed/
data/
data/**
*/data/
